class Solution {
    public long sumAndMultiply(int n) {
        long ans = 0;
        long sum = 0;
        while(n>0){
            int d = n%10;
            if(d!=0){
                ans = (ans*10)+d;
                sum += d;
            }
            n /= 10;
        }
        long x = 0;
        while (ans > 0) {
            x = x * 10 + ans % 10;
            ans /= 10;
        }
        return x*sum;
    }
}
