class Solution {
    public int findMin(int[] nums) {
        int n=nums.length;
        if(n==1)
        return nums[0];
        int l=0,h=n-1,a,m;
        while(l<=h)
        {
            m=(l+h)/2;
            if(nums[m]>nums[m+1])
            return nums[m+1];
            else if(nums[m]<nums[m+1] && nums[m]>nums[n-1])
            l=m+1;
            else
            h=m-1;
        }
        return nums[0];
    }
}
