class Solution {
    public int robotSim(int[] commands, int[][] obstacles) {
        int n = commands.length;
        int x=0,y=0,dir=0;
        int[] dx = {0, 1, 0, -1};
        int[] dy = {1, 0, -1, 0};
        int maxD = 0;

        Set<String> set = new HashSet<>();
        for (int[] obs : obstacles)
            set.add(obs[0] + "," + obs[1]);
        
        for(int i:commands){
            if(i==-1)
            dir = (dir+1)%4;
            else if(i==-2)
            dir = (dir+3)%4;
            else{
                for(int j=0;j<i;j++){
                    int nx = x+dx[dir];
                    int ny = y+dy[dir];
                    if (set.contains(nx + "," + ny))
                    break;
                    x = nx;
                    y = ny;
                    maxD = Math.max(maxD, x * x + y * y);
                }
            }
        }
        return maxD;
    }
}
