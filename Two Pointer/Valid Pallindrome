class Solution {
    public boolean isPalindrome(String s) {
        int n = s.length();
        s = s.toLowerCase();
        int f=0,l=n-1;
        while(f<l){
            if(!Character.isLetterOrDigit(s.charAt(f))) f++;
            else if(!Character.isLetterOrDigit(s.charAt(l))) l--;
            else{
                if(s.charAt(f)==s.charAt(l)){
                    f++;
                    l--;
                }
                else
                return false;
            }
        }
        return true;
    }
}
