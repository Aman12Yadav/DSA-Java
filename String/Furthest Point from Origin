class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int n = moves.length();
        int l=0,r=0;
        for(int i=0;i<n;i++){
            if(moves.charAt(i)=='L') l++;
            else if(moves.charAt(i)=='R') r++;
        }
        int ans = Math.abs(l-r)+(n-l-r);
        return ans;
    }
}
