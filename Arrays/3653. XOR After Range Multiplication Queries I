class Solution {
    public int xorAfterQueries(int[] nums, int[][] queries) {
        int m = queries.length;
        int n = nums.length;
        for(int i=0;i<m;i++){
           int idx = queries[i][0];
           while(idx<=queries[i][1]){
            nums[idx] = (int)((long) nums[idx]*queries[i][3] % 1000000007);
            idx += queries[i][2];
           } 
        }
        int ans = nums[0];
        for(int i=1;i<n;i++){
            ans ^= nums[i];
        }
        return ans;
    }
}
