class Solution {
    public int digsum(int n){
        int sum = 0;
        while(n>0){
            sum += (n%10);
            n /= 10;
        }
        return sum;
    }
    public int minElement(int[] nums) {
        int ans = Integer.MAX_VALUE;
        for(int i:nums){
            int d = digsum(i);
            ans = Math.min(ans,d);
        }
        return ans;
    }
}
