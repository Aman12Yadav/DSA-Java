class Solution {
    public int countSubmatrices(int[][] grid, int k) {
        int m = grid.length;
        int n = grid[0].length;
        int[][] pf = new int[m][n];
        int ans = 0;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                pf[i][j] = grid[i][j];
                if(i>0) pf[i][j] += pf[i-1][j];
                if(j>0) pf[i][j] += pf[i][j-1];
                if(i>0 && j>0) pf[i][j] -= pf[i-1][j-1];
                if(pf[i][j] <= k) ans++;
            }
        }
        return ans;
    }
}
