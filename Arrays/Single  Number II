class Solution {
    public int singleNumber(int[] nums) {
        int n=nums.length;
        int i,j,c=0;
        if(n==1)
        return nums[0];
        for(i=0;i<n;i++)
        {
            for(j=0;j<n;j++)
            {
                if(nums[i]==nums[j])
                c++;
                if(c>1)
                break;
            }
            if(c==1)
            break;
            c=0;
        }
        return nums[i];
    }
}
