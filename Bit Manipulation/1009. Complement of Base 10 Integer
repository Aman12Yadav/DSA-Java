class Solution {
    public int bitwiseComplement(int n) {
        if(n==0)
        return 1;
        String s = "";
        while(n>0){
            if((n&1)==1)
            s="0"+s;
            else
            s ="1"+s;
            n=n>>1;
        }
        int ans = Integer.parseInt(s, 2);
        return ans;
    }


// BIt Manipulation

class Solution {
    public int bitwiseComplement(int n) {
        if(n==0)
        return 1;
        int mask = 0;
        int temp = n;
        while(temp>0){
            mask = (mask << 1) | 1;
            temp >>= 1;
        }
        return n^mask;
    }
}
