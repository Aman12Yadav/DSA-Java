class Solution {
    public boolean searchMatrix(int[][] matrix, int target) {
        int i,j=0,m=matrix.length;
        int n=matrix[0].length;
        int f=0;
        int l=(n*m)-1;
        int mid;
        while(f<=l)
        {
            mid=(f+l)/2;
            if(matrix[mid/n][mid%n]==target)
            return true;
            else if(matrix[mid/n][mid%n]<target)
            f=mid+1;
            else
            l=mid-1;
        }
        
        return false;
    }
}
