class Solution {
    public int majorityElement(int[] nums) {
        HashMap<Integer,Integer> h = new HashMap<>();
        for(int i=0;i<nums.length;i++)
        h.put(nums[i],h.getOrDefault(nums[i],0)+1);
        for(int i=0;i<nums.length;i++)
        {
            int a = h.get(nums[i]);
            if(a>nums.length/2)
            return nums[i];
        }
        return 0;
    }
}
