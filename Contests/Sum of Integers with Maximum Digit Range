Question:
ou are given an integer array nums.

The digit range of an integer is defined as the difference between its largest digit and smallest digit.

For example, the digit range of 5724 is 7 - 2 = 5.

Return the sum of all integers in nums whose digit range is equal to the maximum digit range among all integers in the array.

 

Example 1:

Input: nums = [5724,111,350]

Output: 6074

Solution:
class Solution {
    public int diff(int n){
        int min=10,max=-1;
        while(n>0){
            int d = n%10;
            min = Math.min(min,d);
            max = Math.max(max,d);
            n /= 10;
        }
        return max-min;
    }
    public int maxDigitRange(int[] nums) {
        int n = nums.length;
        int[] range = new int[n];
        int max = 0;
        for(int i=0;i<n;i++){
            int r = diff(nums[i]);
            max = Math.max(max,r);
            range[i] = r;
        }
        int sum=0;
        for(int i=0;i<n;i++){
            if(range[i]==max)
            sum += nums[i];
        }
        return sum;
    }
}
