class Solution {
    public int[] minCost(int[] nums, int[][] queries) {
        int n = nums.length;
        int[] closest = new int[n];
        for(int i=0;i<n;i++){
            if(i==0)
                closest[i] = 1;
            else if(i==n-1)
                closest[i] = n-2;
            else{
                int left = nums[i]-nums[i-1];
                int right = nums[i+1]-nums[i];
                closest[i] = left<=right?i-1:i+1;
            }
        }
        int[] forw = new int[n];
        int[] back = new int[n];
        for (int i=1;i<n;i++) {
            int nor = nums[i]-nums[i-1];
            int sp = (closest[i-1]==i) ? 1 : Integer.MAX_VALUE;
            forw[i] = forw[i - 1] + Math.min(nor, sp);
        }
        for (int i=n-2;i>=0;i--) {
            int nor = nums[i + 1] - nums[i];
            int sp = (closest[i + 1] == i) ? 1 : Integer.MAX_VALUE;
            back[i] = back[i + 1] + Math.min(nor, sp);
        }
        int[] ans = new int[queries.length];
        for(int i=0;i<queries.length;i++){
            int l = queries[i][0];
            int r = queries[i][1];
            if(l<r)
                ans[i] = forw[r]-forw[l];
            else
                ans[i] = back[r]-back[l];
        }
        return ans;
    }
}
