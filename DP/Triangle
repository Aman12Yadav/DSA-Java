class Solution {
    int[][] memo;
    public int minimumTotal(List<List<Integer>> triangle) {
        int n = triangle.size();
        memo = new int[n][n];
        for (int[] row : memo) 
        Arrays.fill(row, Integer.MAX_VALUE);
        return dfs(triangle, 0, 0);
    }
     private int dfs(List<List<Integer>> triangle, int row, int col) {
        if (row == triangle.size() - 1) return triangle.get(row).get(col);
        if (memo[row][col] != Integer.MAX_VALUE) return memo[row][col];
        
        int down = dfs(triangle, row + 1, col);
        int diag = dfs(triangle, row + 1, col + 1);
        return memo[row][col] = triangle.get(row).get(col) + Math.min(down, diag);
    }
}
