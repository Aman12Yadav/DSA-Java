class Solution {
    public int[] findThePrefixCommonArray(int[] A, int[] B) {
        int n = A.length;
        boolean[] seen = new boolean[n+1];
        //boolean[] seenB = new boolean[n+1];
        int[] ans = new int[n];
        int c = 0;
        for(int i=0;i<n;i++){
            if (seen[A[i]]) c++;
            else seen[A[i]] = true;

            if (seen[B[i]]) c++;
            else seen[B[i]] = true;

            ans[i]=c;
        }
        return ans;
    }
}
