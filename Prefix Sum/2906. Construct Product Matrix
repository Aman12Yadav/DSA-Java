class Solution {
    public int[][] constructProductMatrix(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        int total = m*n;
        int[][] ans = new int[m][n];
        long[] prefix = new long[total];
        long[] suffix = new long[total];

        prefix[0] = 1;
        for (int k = 1; k < total; k++) {
            int i = (k - 1) / n, j = (k - 1) % n;
            prefix[k] = (prefix[k - 1] * grid[i][j]) % 12345;
        }

        suffix[total - 1] = 1;
        for (int k = total - 2; k >= 0; k--) {
            int i = (k + 1) / n, j = (k + 1) % n;
            suffix[k] = (suffix[k + 1] * grid[i][j]) % 12345;
        }

        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                int k = i * n + j;
                ans[i][j] = (int)((prefix[k] * suffix[k]) % 12345);
            }
        }

        return ans;
    }
}
